NODE_ENV=development
PORT=3201
DEV_MODE=true
JWT_SECRET=your_jwt_secret_key_here

# Database: use SQLite (default) OR PostgreSQL
DB_PATH=./database/app.db
# DATABASE_URL=postgresql://gitinsider:gitinsider@localhost:5432/gitinsider

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
GIT_REPOS_PATH=./repos
UID=1000
GID=1000

# Performance tuning
WORKSPACE_REPO_CACHE_TTL_SECONDS=300
COMMIT_MONTH_CACHE_TTL_SECONDS=900
GIT_CONCURRENCY=8
GIT_EXCLUDE_MERGES=true
DEFAULT_SINCE_DAYS=0

# Default index window (months) — overridden by Settings UI when saved
# INDEX_WINDOW_MONTHS=3
# Commits per git log batch when indexing (newest first)
# INDEX_BATCH_SIZE=80
